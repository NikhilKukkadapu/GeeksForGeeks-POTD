class Solution {
    public ArrayList<Integer> findDuplicates(int[] arr) {
        // code here
         HashSet<Integer> set = new HashSet<>();

        HashSet<Integer> duplicates = new HashSet<>();

        for(int num : arr) {

            if(!set.add(num)) {

                duplicates.add(num);
            }
        }
        ArrayList<Integer> ans = new ArrayList<>(duplicates);
        return ans;
    }
}
