class Solution {
    public int firstSearch(int[] arr, int k) {
        // Code Here
        int left = 0;
        int right = arr.length - 1;
        int ans = -1;

        while(left <= right) {
            int mid = left + (right - left) / 2;

            if(arr[mid] == k) {
                ans = mid;        // store answer
                right = mid - 1; // search on left side for first occurrence
            }
            else if(arr[mid] < k) {
                left = mid + 1;
            }
            else {
                right = mid - 1;
            }
        }

        return ans;
    }
}
