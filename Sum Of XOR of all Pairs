class Solution {
    public long sumXOR(int[] arr) {
        // code here
        long totalSum = 0;
        int n = arr.length;

        for (int bit = 0; bit < 32; bit++) {
            long count1 = 0;

            for (int num : arr) {
                if ((num & (1 << bit)) != 0) {
                    count1++;
                }
            }

            long count0 = n - count1;
            totalSum += count1 * count0 * (1L << bit);
        }

        return totalSum;
    }
}
