class Solution {
    public boolean wifiRange(String s, int x) {
        // code here
        int n = s.length();
        int coveredTill = -1;

        for (int i = 0; i < n; i++) {

            // If current room is not covered
            if (i > coveredTill) {

                // Need a router that can cover this room
                boolean found = false;

                // Search possible router positions
                for (int j = Math.max(0, i - x);
                         j <= Math.min(n - 1, i + x); j++) {

                    if (s.charAt(j) == '1') {
                        coveredTill = j + x;
                        found = true;
                        break;
                    }
                }

                if (!found) {
                    return false;
                }
            }
        }

        return true;
    }
}
